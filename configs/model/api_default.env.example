# Copy values into `.secrets/providers.env` on the remote server.
# The smoke workflow reads that file directly and resolves one provider profile.

# DashScope (qwen/glm/kimi)
DASHSCOPE_API_KEY=my_dashscope_key
DASHSCOPE_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# MiniMax
MINIMAX_API_KEY=my_minimax_key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

# model names
MODEL_QWEN36=qwen3.6-plus
MODEL_QWEN35=qwen3.5-plus
MODEL_GLM5.1=glm-5.1
MODEL_KIMI2.6=kimi-k2.6
# Legacy aliases kept for compatibility with older configs or env files.
MODEL_GLM5=glm-5.1
MODEL_KIMI25=kimi-k2.6
MODEL_MINIMAX25=MiniMax-M2.5
MODEL_MINIMAX27=MiniMax-M2.7
